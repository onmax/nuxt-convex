{
  "name": "nuxt-convex",
  "type": "module",
  "version": "0.0.6",
  "description": "Nuxt module for Convex powered by vue-convex",
  "author": "onmax",
  "license": "MIT",
  "homepage": "https://github.com/onmax/nuxt-convex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onmax/nuxt-convex.git",
    "directory": "packages/nuxt"
  },
  "bugs": {
    "url": "https://github.com/onmax/nuxt-convex/issues"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "convex",
    "realtime",
    "database",
    "storage",
    "vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./better-auth": {
      "types": "./dist/runtime/better-auth/adapter.d.ts",
      "import": "./dist/runtime/better-auth/adapter.js"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev ../../playground",
    "dev:build": "nuxi build ../../playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare",
    "playground:prepare": "nuxi prepare ../../playground",
    "test": "nuxt-module-build build && vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "nuxt-module-build build"
  },
  "peerDependencies": {
    "@convex-dev/r2": ">=0.9.1",
    "better-auth": ">=1.4.9 <1.6.0",
    "convex": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@convex-dev/r2": {
      "optional": true
    },
    "better-auth": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuxt/kit": "catalog:prod",
    "consola": "catalog:prod",
    "defu": "catalog:prod",
    "pathe": "catalog:prod",
    "vue-convex": "workspace:*"
  },
  "devDependencies": {
    "ofetch": "catalog:",
    "ufo": "catalog:",
    "yaml": "catalog:"
  }
}
