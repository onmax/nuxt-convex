{
  "name": "convex-monorepo",
  "type": "module",
  "version": "0.0.6",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "pnpm --filter nuxt-convex dev",
    "dev:vue": "pnpm --filter convex-vue-example dev",
    "dev:vue:build": "pnpm --filter convex-vue-example build",
    "dev:build": "pnpm --filter nuxt-convex dev:build",
    "dev:prepare": "pnpm --filter nuxt-convex dev:prepare",
    "playground:prepare": "pnpm --filter nuxt-convex playground:prepare",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "lint": "pnpm lint:workspace && pnpm lint:docs",
    "lint:fix": "pnpm lint:workspace:fix && pnpm lint:docs:fix",
    "lint:workspace": "eslint . --ignore-pattern docs",
    "lint:workspace:fix": "eslint . --fix --ignore-pattern docs",
    "lint:docs": "eslint docs/app docs/nuxt.config.ts",
    "lint:docs:fix": "eslint docs/app docs/nuxt.config.ts --fix",
    "typecheck": "pnpm --filter @onmax/convex-vue typecheck && pnpm --filter nuxt-convex typecheck",
    "test": "pnpm --filter @onmax/convex-vue test && pnpm --filter nuxt-convex test",
    "validate:packages": "pnpm build && publint packages/vue && publint packages/nuxt",
    "preview:packages": "mkdir -p .artifacts && pnpm --filter @onmax/convex-vue pack --pack-destination .artifacts && pnpm --filter nuxt-convex pack --pack-destination .artifacts",
    "prepack": "pnpm validate:packages",
    "publish:packages": "pnpm --filter @onmax/convex-vue publish --no-git-checks --provenance --access public && pnpm --filter nuxt-convex publish --no-git-checks --provenance --access public",
    "release": "bumpp && git push --follow-tags"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:lint",
    "@nuxt/devtools": "catalog:nuxt",
    "@nuxt/eslint-config": "catalog:lint",
    "@nuxt/module-builder": "catalog:build",
    "@nuxt/test-utils": "catalog:test",
    "@types/node": "catalog:types",
    "@vitejs/plugin-vue": "catalog:vite",
    "@vue/test-utils": "catalog:test",
    "better-auth": "catalog:playground",
    "bumpp": "catalog:",
    "convex": "catalog:convex",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "jsdom": "catalog:test",
    "nuxt": "catalog:",
    "publint": "catalog:build",
    "tsdown": "catalog:build",
    "typescript": "catalog:build",
    "vite": "catalog:vite",
    "vitest": "catalog:test",
    "vitest-package-exports": "catalog:test",
    "vue": "catalog:nuxt"
  }
}
