{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nuxt-convex-playground",
  "compatibility_date": "2026-03-22",
  "compatibility_flags": [
    "nodejs_compat",
    "no_nodejs_compat_v2"
  ],
  "main": ".output/server/index.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": ".output/public"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "NUXT_PUBLIC_SITE_URL": "https://nuxt-convex-playground.je-cf9.workers.dev"
  }
}
